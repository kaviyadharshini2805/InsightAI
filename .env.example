# ============================================================
# InsightAI – Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual keys.
# All values are optional except OPENAI_API_KEY and TAVILY_API_KEY.

# ── OpenAI (required) ──────────────────────────────────────
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key


# Optional: specify the model used for research & summarization
# Defaults to gpt-4o-mini if not set.
# OPENAI_MODEL=gpt-4o-mini

# Optional: specify a different model for account plan generation
# Defaults to the same as OPENAI_MODEL if not set.
# OPENAI_PLAN_MODEL=gpt-4o

# ── Tavily Search (required) ────────────────────────────────
# Get your key at: https://tavily.com
TAVILY_API_KEY=your_tavily_api_key

# ── Firecrawl (optional) ──────────────────────────────────
# If set, used for enhanced web scraping; otherwise falls back to BeautifulSoup.
# Get your key at: https://firecrawl.dev
# FIRECRAWL_API_KEY=your_firecrawl_api_key
# ── Logging ──────────────────────────────────────────────
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ── App Settings (optional) ─────────────────────────────
# Streamlit runs on port 8501 by default; you can override via Streamlit config.
# APP_PORT=8501

# ── Agent Tuning (optional) ─────────────────────────────
# Maximum number of sources per research query
# MAX_SOURCES=10
# Confidence threshold for conflict detection (0.0–1.0)
# CONFLICT_THRESHOLD=0.4
# Max retries per agent node
# NODE_MAX_RETRIES=2

# ── IMPORTANT ────────────────────────────────────────────
# This app uses Streamlit Session State for all persistence.
# No database (SQLite, PostgreSQL, etc.) is required.
# Do not set SESSION_BACKEND or SQLITE_DB_PATH.